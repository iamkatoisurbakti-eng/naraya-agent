# === Naraya-Agent — contoh environment. Salin ke .env lalu isi yang dibutuhkan. ===

# ---------------------------------------------------------------------------
# PROVIDER LLM — pilih salah satu (atau biarkan auto-deteksi dari key yang terisi).
#   nilai: naraouter | openai | anthropic | openrouter | kilocode | custom | custom_endpoint
#   ganti cepat: python core/select_provider.py  (atau set NARAYA_PROVIDER di bawah)
NARAYA_PROVIDER=
NARAYA_MODEL=
NARAYA_JUDGE_MODEL=
# fallback key umum (dipakai bila key spesifik provider kosong):
NARAYA_API_KEY=

# NaraRouter (https://router.naraya.ai/v1) — model contoh: auto/naraya.ai
NARAROUTER_API_KEY=
# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=
# Anthropic (Claude) — butuh: pip install anthropic
ANTHROPIC_API_KEY=
# OpenRouter (https://openrouter.ai/api/v1)
OPENROUTER_API_KEY=
# Kilo Code (https://api.kilo.ai/api/gateway)
KILOCODE_API_KEY=
# Custom direct API (OpenAI-compatible)
NARAYA_CUSTOM_BASE_URL=
NARAYA_CUSTOM_API_KEY=
NARAYA_CUSTOM_MODEL=
# Custom Endpoint API (OpenAI-compatible)
NARAYA_ENDPOINT_URL=
NARAYA_ENDPOINT_API_KEY=
NARAYA_ENDPOINT_MODEL=

# Model multimodal (gaya OpenAI)
NARAYA_VISION_MODEL=gpt-4o-mini
NARAYA_IMAGE_MODEL=gpt-image-1
NARAYA_TTS_MODEL=tts-1
NARAYA_TTS_VOICE=alloy
NARAYA_STT_MODEL=whisper-1

# Folder kerja untuk tool terminal (opsional; default: cwd)
NARAYA_HOME=

# Messaging
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
NARAYA_WEBHOOK_URL=

# Home Assistant
HA_URL=
HA_TOKEN=

# X / Twitter (search)
X_BEARER_TOKEN=

# Loop evolusi otonom (menit)
NARAYA_EVO_INTERVAL_MIN=60
